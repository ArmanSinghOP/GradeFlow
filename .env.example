POSTGRES_USER=gradeflow
POSTGRES_PASSWORD=gradeflow_secret
POSTGRES_DB=gradeflow_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://gradeflow:gradeflow_secret@db:5432/gradeflow_db
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
OPENAI_API_KEY=sk-your-key-here
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=100
MAX_CLUSTER_SIZE=50
MIN_CLUSTER_SIZE=10
ANCHOR_SET_PATH=./anchors
LOG_LEVEL=INFO
ENVIRONMENT=development
